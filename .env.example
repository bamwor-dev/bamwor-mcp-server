# Bamwor MCP Server — Environment Variables
# Copy to .env and fill in your values

# REQUIRED: Your Bamwor API key (register free at https://bamwor.com/developers/quickstart)
BAMWOR_API_KEY=bw_live_your_key_here

# OPTIONAL: Override API base URL (default: https://bamwor.com/api/v1)
# BAMWOR_API_URL=https://bamwor.com/api/v1
